# CineTrack - Environment Variables
# Copy this file to .env.local and fill in your API keys.

# TMDB API Key (Required)
# Get your free API key at: https://www.themoviedb.org/settings/api
# Use the v3 auth API Read Access Token.
NEXT_PUBLIC_TMDB_KEY=

# OpenSubtitles API Key (Optional - for subtitle support)
# Get your API key at: https://www.opensubtitles.com/en/consumers
NEXT_PUBLIC_OPENSUBTITLES_KEY=

# Supabase (Required - for authentication & data sync)
# Get your keys at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
